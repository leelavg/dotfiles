#====== Prompt [https://linux.101hacks.com/ps1-examples/prompt-color-using-tput/] {{{


if [ -n "$SSH_TTY" ] || [ -n "$SSH_CLIENT" ]; then
    #-- Remote
    hname=`command -v hostname 1>/dev/null && echo $(hostname -i) | awk '{print $NF}'`
    hname=${hname:=DUMMY}
    etc_host=$(grep -P "$hname\b" $hosts_file | tr -s ' ' | awk '{print $(NF)}')
    PS1="\n\[$(tput bold)$(tput setaf 6)\]\u@\[$(tput bold)$(tput setaf 1)\]\h \[$(tput bold)$(tput setaf 4)\]$etc_host \[$(tput bold)$(tput setaf 2)\]\w $PS2\[$(tput bold)$(tput setaf 7)\]\n\\$ \[$(tput sgr0)\]"
    # PS1=$(echo $prompt | tr -s ' ')
else
    #-- Local
    PROMPT_DIRTRIM=2
    PS1="\[$(tput bold)$(tput setaf 1)\]\w \[$(tput bold)$(tput setaf 7)\]\\$ \[$(tput sgr0)\]"
fi

s gpy3 # Activate Gluster Python 3 virtualenv

