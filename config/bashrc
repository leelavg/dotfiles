pyc () {

    # Lint and Fix python files
    printf "\n%10s Sorting imports by 'isort'\n"; isort "$@";
    printf "\n%10s Running through 'yapf'\n"; yapf -i "$@";
    printf "\n%10s Checking against 'flake8'\n"; flake8 "$@";
    printf "\n%10s Errors from 'pylint'\n"; pylint --rcfile=.pylintrc "$@";

}

s () {

    # Use `fzf` to select and launch python virtualenv
    if [ -d ~/toolbox ] && command -v fzf 1>/dev/null;
    then
        source ~/toolbox/venv/$([ ! -z $1 ] && echo $1 || echo $(ls ~/toolbox/venv | fzf))/bin/activate
        PS1="\n${PS1-}"
    fi

}


