nv () {

    # Exec NeoVim with correct config files or download, configureand launch
    if command -v nvim 1>/dev/null; then
        command nvim -u $cwd/.init.vim "$@";
    else
        if [ ! -e $HOME/.nvim/nvim.appimage ]; then
