#====== Source any other Run Commands
set -m
source ~/.profile
source ~/.bash_aliases

#====== All about bash history
export HISTCONTROL=ignoreboth:erasedups
export HISTSIZE=10000
export HISTFILESIZE=20000
shopt -s histappend
shopt -s cmdhist
#-- Archive bash history
KEEP=200
for FILE in ~/.bash_history
do
    BACKUP=$FILE.$(date +%y%m)
    if [ -s "$FILE" -a "$FILE" -nt "$BACKUP" ]; then
        # history file is newer than backup
        if [[ -f $BACKUP ]]; then
            # there is already a backup
            cp -f $FILE $BACKUP
        else
            # create new backup, leave last few commands and reinitialize
            mv -f $FILE $BACKUP
            tail -n$KEEP $BACKUP > $FILE
            history -r
        fi
    fi
done

#====== Prompt
#-- Simple
export PROMPT_DIRTRIM=1
export PS1='$(if [[ $? == 0 ]]; then echo "\e[1;32m:)"; else echo "\e[1;31m:("; fi)\e[1;34m \w > \e[m'
